# Versions are exact-pinned (==X.Y.Z) so OSV-Scanner can resolve a single
# concrete version per line. Wildcards (==X.*) prevented the scanner from
# matching the actual installed version and produced false-positive CVE
# reports across the major series. Dependabot's weekly minor/patch group
# (see .github/dependabot.yml) keeps these moving.
Flask==3.1.3
firebase-admin==7.4.0
flask-wtf==1.3.0
flask-limiter==4.1.1
gunicorn==25.3.0
google-cloud-firestore==2.27.0
google-cloud-storage==3.10.1
google-cloud-secret-manager==2.27.0
google-cloud-logging==3.15.0
# OpenTelemetry — distributed tracing → Cloud Trace.
# Versions paired: SDK 1.27 ↔ instrumentation 0.48b0 (OTel's stable+beta
# split).  GCP exporter 1.7.0 is the latest line tested against SDK 1.27.
opentelemetry-api==1.27.0
opentelemetry-sdk==1.27.0
opentelemetry-exporter-gcp-trace==1.7.0
opentelemetry-propagator-gcp==1.7.0
opentelemetry-instrumentation-flask==0.48b0
opentelemetry-instrumentation-requests==0.48b0
opentelemetry-instrumentation-jinja2==0.48b0
icalendar==7.0.3
vobject==0.9.9
bcrypt==5.0.0
python-dotenv==1.2.2
reportlab==4.4.10
# Pillow is a transitive dependency of reportlab (which only requires >=9.0.0).
# Pinned explicitly here for CVE hygiene. 12.3.0 clears a batch of 2026
# image-decoder advisories (CVE-2026-54059 / 54060 / 55379 / 55380 / 55798 /
# 59199 / 59203 / 59205) on top of the earlier CVE-2023-44271 (Pillow <10),
# CVE-2026-25990 (PSD OOB write) and CVE-2026-40192 (FITS GZIP decompression
# bomb). None are reachable here — reportlab emits tabular PDFs and no
# untrusted image is ever decoded (no `import PIL` anywhere) — so this is a
# hygiene bump.
Pillow==12.3.0
Markdown==3.10.2
# bleach is archived upstream; 6.4.0 is a security release clearing the
# URI-scheme sanitization advisories (GHSA-gj48-438w-jh9v, GHSA-8rfp-98v4-mmr6)
# and moving off the 6.3.0-only linkify email-DoS advisory (GHSA-g75f-g53v-794x).
# Longer term, migrate note sanitization to nh3 (maintained successor) to exit
# this recurring class of unpatched bleach alerts.
bleach==6.4.0
defusedxml==0.7.1
# Transitive deps pinned explicitly for CVE hygiene (same rationale as Pillow):
# both arrive via the google/firebase client stack. cryptography 48.0.1 ships a
# patched bundled OpenSSL (GHSA-537c-gmf6-5ccf); msgpack 1.2.1 fixes an Unpacker
# out-of-bounds read after a caught error (GHSA-6v7p-g79w-8964).
cryptography==48.0.1
msgpack==1.2.1
# opentelemetry-instrumentation 0.48b0 imports pkg_resources at runtime,
# which setuptools removed in 81+ — with a newer setuptools the OTel Flask
# auto-instrumentation fails ("No module named 'pkg_resources'") and tracing
# silently disables. Constrain until the OTel stack is bumped to >=0.50b0
# (which dropped the pkg_resources dependency).
setuptools<81
