# Firebase build and deployment files
/firebase-debug.log
/firebase-debug.*.log
.firebaserc

# Firebase Hosting
# (firebase.json is committed — it maps the Firestore/Storage rules files
# for `firebase deploy --only firestore:rules,storage`)
*.cache
hosting/.cache

# Firebase Functions
/functions/node_modules/
/functions/.env
/functions/package-lock.json

# Firebase Emulators
/firebase-*.zip
/.firebase/
/emulator-ui/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Environment files (local configs) — unanchored so athena/.env etc. are
# covered too; only the committed template is allowed.
.env
.env.*
!.env.example

# Service account keys
**/service-account*.json
**/*-adminsdk-*.json

# Claude related files
.claude
.claude/
.claude/settings.local.json

# Python cache files
/__pycache__
/__pycache__/*
/__pycache__/*.pyc
*.pyc

# Python
__pycache__/
*.pyc
*.pyo
venv/
.venv/
