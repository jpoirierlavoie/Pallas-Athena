# Pallas Athena — local development environment template.
# Copy to .env (gitignored) and fill in real values. Production does NOT use
# this file: sensitive values come from Google Cloud Secret Manager
# (see athena/config.py) and identifiers from athena/app.yaml.

# Environment
ENV=development

# Flask session signing key — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Firebase / GCP identifiers (non-secret)
FIREBASE_PROJECT_ID=athena-pallas
FIREBASE_APP_ID=
FIREBASE_STORAGE_BUCKET=athena-pallas.firebasestorage.app
# Public-by-design web API key (still kept out of git)
FIREBASE_API_KEY=

# Single authorized user
AUTHORIZED_USER_EMAIL=

# Session
SESSION_LIFETIME_HOURS=12

# DAV Basic Auth — bcrypt hash of the DAV password
# python -c "import bcrypt; print(bcrypt.hashpw(b'<password>', bcrypt.gensalt()).decode())"
DAV_PASSWORD_HASH=

# App Check (reCAPTCHA Enterprise); APPCHECK_DEBUG_TOKEN is local-dev only
RECAPTCHA_ENTERPRISE_SITE_KEY=
APPCHECK_DEBUG_TOKEN=

# Multi-factor authentication enforcement (server-side gate)
REQUIRE_MFA=true

# Rate limiting
RATE_LIMIT_LOGIN=5 per minute

# Cloudflare origin secret (optional): when set, every request must carry the
# same value in X-Origin-Auth (injected by a Cloudflare Transform Rule).
# Leave empty in local dev.
CF_ORIGIN_SECRET=

# MCP connector (Phase I). MCP_ENABLED=false is the kill switch (all
# /mcp + /oauth/* routes 404). MCP_CANONICAL_ORIGIN is the OAuth issuer —
# override for local MCP Inspector testing, e.g. http://localhost:8080
MCP_ENABLED=true
MCP_CANONICAL_ORIGIN=http://localhost:8080

# Firm info (invoices)
FIRM_NAME=
FIRM_STREET=
FIRM_UNIT=
FIRM_CITY=
FIRM_PROVINCE=QC
FIRM_POSTAL_CODE=
FIRM_PHONE=
FIRM_EMAIL=
GST_NUMBER=
QST_NUMBER=
